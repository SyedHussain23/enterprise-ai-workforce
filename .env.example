# Copy this to .env and fill in your values. Never commit .env to git.

# ── App ──────────────────────────────────────────────────────────────────────
DEBUG=false
SECRET_KEY=generate-a-32-char-random-string-here

# ── Database ─────────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=enterprise_ai
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/enterprise_ai
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:postgres@localhost:5432/enterprise_ai

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# ── LangSmith (optional) ─────────────────────────────────────────────────────
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=enterprise-ai-workforce

# ── CORS (production only) ───────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins in production
# Set this to your Vercel deployment URL
# Example: https://enterprise-ai-workforce.vercel.app
ALLOWED_ORIGINS=

# ── WhatsApp (optional) ───────────────────────────────────────────────────────
# Get from: Meta Developers → Your App → WhatsApp → Configuration
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=enterprise_ai_verify
